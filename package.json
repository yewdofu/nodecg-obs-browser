{
	"name": "nodecg-obs-browser",
	"version": "1.0.0",
	"scripts": {
		"dev": "run-p dev:*",
		"dev:tsc": "tsc -b src/browser src/extension -w --preserveWatchOutput",
		"dev:vite": "vite",
		"dev:nodecg": "npx nodecg start",
		"generate-schema-types": "nodecg schema-types -o ./src/types/generated",
        "clean": "trash node_modules/.cache && trash dashboard && trash extension",
		"build": "vite build"
	},
	"nodecg": {
		"compatibleRange": "^2.0.0",
		"assetCategories": [
			{
				"name": "test",
				"title": "Test",
				"allowedTypes": [
					"jpg",
					"jpeg",
					"gif",
					"png"
				]
			}
		],
		"dashboardPanels": [
			{
				"name": "switch-scene",
				"title": "シーン切り替え",
				"width": 2,
				"file": "SwitchScene.html",
				"workspace": "Example",
				"headerColor": "#525F78"
			}
		],
		"graphics": [
			{
				"file": "ObsControl.html",
				"width": 1920,
				"height": 1080,
				"singleInstance": true
			}
		]
	},
	"devDependencies": {
		"@emotion/react": "^11.13.3",
		"@emotion/styled": "^11.13.0",
		"@mdi/react": "^1.6.1",
		"@mui/material": "^6.1.1",
		"@nodecg/types": "^2.1.12",
		"@types/obs-studio": "^2.17.2",
		"@types/react": "^18.3.8",
		"@types/react-dom": "^18.3.0",
		"@vitejs/plugin-react": "^6.0.1",
		"globby": "^14.0.2",
		"nodecg": "^2.6.1",
		"npm-run-all": "^4.1.5",
		"prettier-plugin-organize-imports": "^4.2.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"trash-cli": "^6.0.0",
		"typescript": "^5.6.2",
		"vite": "^8.0.3"
	},
	"dependencies": {
		"@nodecg/react-hooks": "^1.0.3",
		"tslib": "^2.7.0"
	}
}
